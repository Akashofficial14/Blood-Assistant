<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Verified | YourBrand</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes scaleIn {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        .animate-check { animation: scaleIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    </style>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen font-sans">

    <div class="bg-white p-8 rounded-2xl shadow-xl max-w-md w-full text-center border border-slate-100">
        <div class="mb-6 flex justify-center">
            <div class="bg-green-100 text-green-600 w-20 h-20 rounded-full flex items-center justify-center animate-check">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
            </div>
        </div>

        <h1 class="text-3xl font-bold text-slate-800 mb-2">Email Verified!</h1>
        <p class="text-slate-500 mb-8">
            Thank you for verifying your email address. Your account is now fully active.
        </p>

        <div class="bg-slate-50 rounded-lg p-4 mb-6 border border-slate-200">
            <p class="text-sm text-slate-600">
                You will be automatically redirected to the login page in <span id="countdown" class="font-bold text-blue-600">5</span> seconds.
            </p>
        </div>

        <a href="http://localhost:5173/login" class="inline-block w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-200">
            Go to Login Now
        </a>
    </div>

    <script>
        // Redirect Logic
        let seconds = 5;
        const countdownEl = document.getElementById('countdown');
        
        const timer = setInterval(() => {
            seconds--;
            countdownEl.textContent = seconds;
            if (seconds <= 0) {
                clearInterval(timer);
                window.location.href = "http://localhost:5173/login"; // Change this to your actual login route
            }
        }, 1000);
    </script>
</body>
</html>